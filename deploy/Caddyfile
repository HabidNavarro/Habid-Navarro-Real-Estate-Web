:8080 {
	root * /srv
	encode gzip zstd
	file_server

	# Esto es una VISTA PREVIA, no el sitio publico. Nunca debe indexarse: si Google
	# la levantara competiria con habidnavarro.com y podria confundir a un cliente.
	header X-Robots-Tag "noindex, nofollow"
	header X-Content-Type-Options "nosniff"
	header Referrer-Policy "strict-origin-when-cross-origin"

	# Astro genera 404.html; sin esto Caddy devuelve su error crudo.
	handle_errors {
		@notfound expression {err.status_code} == 404
		handle @notfound {
			rewrite * /404.html
			file_server
		}
	}

	log {
		output stdout
		format console
	}
}
