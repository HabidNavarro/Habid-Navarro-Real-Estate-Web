---
import Icon from './Icon.astro';
interface Props { amenidades: string[]; }
const { amenidades } = Astro.props;
function iconName(a: string): string {
  const k = a.toLowerCase();
  if (k.includes('recámara') || k.includes('recamara') || k.includes('habitac')) return 'bed';
  if (k.includes('baño') || k.includes('bano')) return 'bath';
  if (k.includes('jard')) return 'tree';
  if (k.includes('lago') || k.includes('vista')) return 'mountain';
  if (k.includes('roof') || k.includes('terraza')) return 'sun';
  if (k.includes('bodega')) return 'box';
  if (k.includes('cocina') || k.includes('alacena')) return 'kitchen';
  if (k.includes('estudio')) return 'book';
  if (k.includes('tv') || k.includes('salita')) return 'tv';
  if (k.includes('servicio')) return 'wash';
  if (k.includes('cochera') || k.includes('portón') || k.includes('porton') || k.includes('auto')) return 'car';
  if (k.includes('concreto') || k.includes('estructura') || k.includes('colad') || k.includes('cimi')) return 'structure';
  if (k.includes('nivel') || k.includes('planta') || k.includes('crecer') || k.includes('ampli')) return 'levels';
  if (k.includes('aljibe') || k.includes('boiler') || k.includes('agua') || k.includes('cisterna')) return 'drop';
  if (k.includes('protec') || k.includes('mosquit') || k.includes('reja') || k.includes('segur') || k.includes('caseta') || k.includes('vigil')) return 'shield';
  if (k.includes('patio') || k.includes('encement')) return 'patio';
  if (k.includes('alberca')) return 'pool';
  return 'check';
}
---
<div class="amenities">
  {amenidades.map((a) => (
    <div class="amenity">
      <span class="amenity-ico"><Icon name={iconName(a)} size={20} /></span>
      <span class="amenity-name">{a}</span>
    </div>
  ))}
</div>
<style>
  .amenities{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:12px}
  .amenity{padding:16px;background:var(--surface);border:1px solid transparent;border-radius:14px;display:flex;align-items:center;gap:13px;transition:background .18s ease,transform .18s ease}
  .amenity:hover{transform:translateY(-2px);background:#eef0f3}
  .amenity-ico{flex:none;display:grid;place-items:center;width:42px;height:42px;border-radius:11px;background:rgba(43,124,196,.1);color:var(--accent)}
  .amenity-name{font-weight:500;font-size:15px;line-height:1.3;color:var(--text)}
</style>
