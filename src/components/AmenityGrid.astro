---
interface Props { amenidades: string[]; }
const { amenidades } = Astro.props;
function icon(a: string): string {
  const k = a.toLowerCase();
  if (k.includes('recámara') || k.includes('recamara') || k.includes('habitac')) return '🛏️';
  if (k.includes('baño') || k.includes('bano')) return '🚿';
  if (k.includes('jard')) return '🌳';
  if (k.includes('lago') || k.includes('vista')) return '🌅';
  if (k.includes('roof') || k.includes('terraza')) return '🏙️';
  if (k.includes('bodega')) return '📦';
  if (k.includes('cocina') || k.includes('alacena')) return '🍳';
  if (k.includes('estudio')) return '📚';
  if (k.includes('tv') || k.includes('salita')) return '📺';
  if (k.includes('servicio')) return '🧺';
  if (k.includes('cochera') || k.includes('portón') || k.includes('porton') || k.includes('auto')) return '🚗';
  if (k.includes('concreto') || k.includes('estructura') || k.includes('colad') || k.includes('cimi')) return '🏗️';
  if (k.includes('nivel') || k.includes('planta') || k.includes('crecer') || k.includes('terraza') || k.includes('ampli')) return '🏠';
  if (k.includes('aljibe') || k.includes('boiler') || k.includes('agua') || k.includes('cisterna')) return '💧';
  if (k.includes('protec') || k.includes('mosquit') || k.includes('reja')) return '🛡️';
  if (k.includes('patio') || k.includes('encement')) return '🧱';
  // Amenidades de desarrollo (legado)
  if (k.includes('alberca')) return '🏊';
  if (k.includes('cine')) return '🎬';
  if (k.includes('salón') || k.includes('salon') || k.includes('evento')) return '🎉';
  if (k.includes('verde') || k.includes('área') || k.includes('area')) return '🌳';
  if (k.includes('segur') || k.includes('caseta')) return '🛡️';
  if (k.includes('gim')) return '🏋️';
  return '✨';
}
---
<div class="amenities">
  {amenidades.map((a) => (
    <div class="amenity card">
      <span class="amenity-ico" aria-hidden="true">{icon(a)}</span>
      <span class="amenity-name">{a}</span>
    </div>
  ))}
</div>
<style>
  .amenities{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:12px}
  .amenity{padding:16px;background:var(--surface);border:1px solid transparent;border-radius:14px;display:flex;align-items:center;gap:13px;transition:background .18s ease,transform .18s ease}
  .amenity:hover{transform:translateY(-2px);background:#eef0f3}
  .amenity-ico{flex:none;display:grid;place-items:center;width:42px;height:42px;border-radius:11px;font-size:20px;background:rgba(43,124,196,.1)}
  .amenity-name{font-weight:500;font-size:15px;line-height:1.3;color:var(--text)}
</style>
