---
import { site } from '../data/content';
interface Props { title: string; description?: string; image?: string; noindex?: boolean; }
const { title, description = site.tagline, image = '/img/og-default.jpg', noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.site_url).href;
const ogImage = new URL(image, site.site_url).href;
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content="#2B7CC4" />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
{noindex
  ? <meta name="robots" content="noindex,nofollow" />
  : <link rel="canonical" href={canonical} />}
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
