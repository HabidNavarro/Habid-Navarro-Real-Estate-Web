---
import { waLink, site } from '../data/site';
import { propiedadDestacada } from '../data/propiedades';
const p = propiedadDestacada;
---
<section class="hero">
  <div class="hero-bg" style={`background-image:url(${p.galeria[0]})`}></div>
  <div class="hero-fade"></div>
  <div class="container hero-inner">
    <p class="eyebrow rise d1">Habid Navarro · Bienes Raíces</p>
    <h1 class="hero-title rise d1">Tu próxima propiedad<br />en Jalisco</h1>
    <p class="hero-sub rise d2">Asesoría honesta y sin presión. Conoce las propiedades disponibles.</p>
    <div class="hero-cta rise d2">
      <a class="btn btn-primary" href="/propiedades">Ver propiedades</a>
      <a class="btn btn-wa" href={waLink()} target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</section>
<style>
  .hero{position:relative;min-height:90vh;display:flex;align-items:flex-end;justify-content:center;text-align:center;overflow:hidden}
  .hero-bg{position:absolute;inset:0;background-size:cover;background-position:center 28%}
  .hero-fade{position:absolute;inset:0;background:
    linear-gradient(180deg,rgba(255,255,255,.12) 0%,rgba(255,255,255,0) 20%,rgba(255,255,255,.52) 47%,rgba(255,255,255,.9) 72%,#fff 100%)}
  .hero-inner{position:relative;z-index:1;padding-bottom:12vh;max-width:760px}
  .hero-title{font-size:clamp(42px,7vw,82px);font-weight:600;letter-spacing:-.032em;color:var(--text);text-shadow:0 1px 22px rgba(255,255,255,.6)}
  .hero-sub{margin:18px auto 0;max-width:520px;font-size:20px;color:var(--muted);line-height:1.4}
  .hero-cta{display:flex;gap:14px;justify-content:center;margin-top:30px;flex-wrap:wrap}
  @media(max-width:560px){.hero{min-height:86vh}.hero-sub{font-size:18px}.hero-inner{padding-bottom:9vh}}
</style>
