---
interface Props { imagenes: string[]; alt: string; }
const { imagenes, alt } = Astro.props;
---
<div class="gallery">
  {imagenes.map((src, i) => (
    <button type="button" class={`g-item ${i === 0 ? 'g-lead' : ''}`} data-idx={i} aria-label={`${alt} — ver foto ${i + 1}`}>
      <img src={src} alt={`${alt} — foto ${i + 1}`} loading="lazy" />
    </button>
  ))}
</div>

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Galería de fotos" aria-hidden="true">
  <button class="lb-btn lb-close" id="lbClose" aria-label="Cerrar galería">&times;</button>
  <button class="lb-btn lb-nav lb-prev" id="lbPrev" aria-label="Foto anterior">&#8249;</button>
  <figure class="lb-stage">
    <img id="lbImg" src="" alt="" />
    <figcaption class="lb-count" id="lbCount"></figcaption>
  </figure>
  <button class="lb-btn lb-nav lb-next" id="lbNext" aria-label="Foto siguiente">&#8250;</button>
</div>

<style>
  .gallery{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:200px;gap:12px}
  .g-item{position:relative;overflow:hidden;border-radius:16px;border:1px solid var(--border);padding:0;cursor:pointer;background:var(--surface);transition:transform .2s ease,box-shadow .2s ease}
  .g-item:hover{transform:translateY(-2px);box-shadow:var(--shadow-sm)}
  .g-item img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
  .g-item:hover img{transform:scale(1.05)}
  .g-lead{grid-column:span 2;grid-row:span 2}
  @media(max-width:680px){.gallery{grid-template-columns:repeat(2,1fr);grid-auto-rows:150px}.g-lead{grid-column:span 2;grid-row:span 1}}

  .lightbox{position:fixed;inset:0;z-index:200;display:none;align-items:center;justify-content:center;background:rgba(10,12,16,.92);backdrop-filter:blur(8px);padding:24px}
  .lightbox.open{display:flex}
  .lb-stage{position:relative;display:flex;flex-direction:column;align-items:center;gap:14px;max-width:min(1120px,94vw)}
  .lb-stage img{max-width:100%;max-height:80vh;object-fit:contain;border-radius:14px;box-shadow:0 24px 70px rgba(0,0,0,.55)}
  .lb-count{font-size:14px;color:rgba(255,255,255,.82);font-weight:500;letter-spacing:.04em}
  .lb-btn{border:none;background:rgba(255,255,255,.13);color:#fff;cursor:pointer;display:grid;place-items:center;line-height:1;transition:background .18s ease}
  .lb-btn:hover{background:rgba(255,255,255,.24)}
  .lb-close{position:fixed;top:18px;right:22px;width:46px;height:46px;border-radius:50%;font-size:28px}
  .lb-nav{position:fixed;top:50%;transform:translateY(-50%);width:54px;height:54px;border-radius:50%;font-size:30px}
  .lb-prev{left:20px}.lb-next{right:20px}
  @media(max-width:560px){.lb-nav{width:44px;height:44px;font-size:26px}.lb-prev{left:8px}.lb-next{right:8px}.lb-close{top:10px;right:12px}}
</style>

<script define:vars={{ imagenes, alt }}>
  (() => {
    const lb = document.getElementById('lightbox');
    if (!lb) return;
    const img = document.getElementById('lbImg');
    const count = document.getElementById('lbCount');
    let idx = 0;
    const show = (i) => {
      idx = (i + imagenes.length) % imagenes.length;
      img.src = imagenes[idx];
      img.alt = `${alt} — foto ${idx + 1}`;
      count.textContent = `${idx + 1} / ${imagenes.length}`;
    };
    const open = (i) => { show(i); lb.classList.add('open'); lb.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; };
    const close = () => { lb.classList.remove('open'); lb.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; };
    document.querySelectorAll('.g-item').forEach((b) => b.addEventListener('click', () => open(Number(b.dataset.idx))));
    document.getElementById('lbClose').addEventListener('click', close);
    document.getElementById('lbPrev').addEventListener('click', (e) => { e.stopPropagation(); show(idx - 1); });
    document.getElementById('lbNext').addEventListener('click', (e) => { e.stopPropagation(); show(idx + 1); });
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });
  })();
</script>
